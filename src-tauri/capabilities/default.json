{
  "identifier": "default",
  "description": "Default capabilities for CashPilot Desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-set-size",
    "shell:allow-open",
    "updater:default"
  ]
}

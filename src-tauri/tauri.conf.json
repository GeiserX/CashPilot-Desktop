{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "CashPilot Desktop",
  "version": "0.1.5",
  "identifier": "com.cashpilot.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "CashPilot",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "iconPath": "../src/assets/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "sidecar/.gitkeep"
    ],
    "macOS": {
      "signingIdentity": null,
      "providerShortName": null
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": ["docker-ce | docker.io"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/GeiserX/CashPilot-Desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBNjQ1NzRCQzk5M0IxODcKUldTSHNaUEpTMWRrS3ZuL2J6UTZkUE83elhJNHFaY3FCVXhqeGk5dFl4QVJzRnhkTXVGV1VoZU4K"
    }
  }
}
